# Blockamok Remix – Windows (MSYS2 MinGW64) build
# Usage: make -f Makefiles/Makefile_pc            (64-bit, default)
#        make -f Makefiles/Makefile_pc LOW_END=1  (extra low-end tuning)

OBJ_DIR    := build_win64
EXE        := BlockamokRemix.exe

SRC_DIR    := src
SRCS       := $(wildcard $(SRC_DIR)/*.c) $(wildcard $(SRC_DIR)/**/*.c)
OBJS       := $(SRCS:%.c=$(OBJ_DIR)/%.o)

RES_RC     := release-resources/resource.rc
RES_OBJ    := $(OBJ_DIR)/resource.o

CC         := x86_64-w64-mingw32-g++
PKG        := pkgconf

# ── Optimisation profile ─────────────────────────────────────────────────────
# Default: -O2 -march=x86-64 (runs on anything from ~2008 onward)
# LOW_END=1: -Os -march=i686 (aggressively minimise code size + cache pressure)
ifeq ($(LOW_END),1)
OPT_FLAGS := -Os -march=i686 -mtune=generic -DLOW_SPEC_BG -DFORCE_DRAW_OVERLAY
else
OPT_FLAGS := -O2 -march=x86-64 -mtune=generic
endif

CFLAGS := $(OPT_FLAGS) -Wall -Wextra \
          -DPC -D_WIN32 \
          -ffunction-sections -fdata-sections -flto=4 \
          $(shell $(PKG) --static --cflags sdl2)

LDFLAGS := -static -static-libgcc \
           $(shell $(PKG) --static --libs sdl2 SDL2_mixer SDL2_ttf) \
           -Wl,--gc-sections -s -flto

.PHONY: all clean

all: $(EXE)

$(EXE): $(OBJS) $(RES_OBJ)
	$(CC) $(OBJS) $(RES_OBJ) $(LDFLAGS) -o $@

$(OBJ_DIR)/%.o: %.c
	mkdir -p $(dir $@)
	$(CC) -c $< $(CFLAGS) -o $@

$(RES_OBJ): $(RES_RC)
	mkdir -p $(dir $@)
	windres $< -O coff -o $@

clean:
	rm -rf $(OBJ_DIR) $(EXE)
