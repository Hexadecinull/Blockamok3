# Blockamok Remix – Linux build
# Usage: make -f Makefiles/Makefile_linux            (default)
#        make -f Makefiles/Makefile_linux LOW_END=1  (low-end mode)

OBJ_DIR := ./build_linux
EXE     := blockamokremix

SRC_DIR := src
SRCS    := $(wildcard $(SRC_DIR)/*.c) $(wildcard $(SRC_DIR)/**/*.c)
OBJS    := $(patsubst %.c, $(OBJ_DIR)/%.o, $(SRCS))

CC         ?= gcc
SDLCONFIG  ?= sdl2-config

ifeq ($(LOW_END),1)
OPT_FLAGS  := -Os -march=x86-64 -mtune=generic -DLOW_SPEC_BG -DFORCE_DRAW_OVERLAY
else
OPT_FLAGS  := -O2 -march=x86-64 -mtune=generic
endif

CFLAGS  ?= $(OPT_FLAGS) -Wall -Wextra -DLINUX -DPC
LDFLAGS ?= -lSDL2_ttf -lSDL2_mixer -lmikmod

CFLAGS  += `$(SDLCONFIG) --cflags`
LDFLAGS += `$(SDLCONFIG) --libs` -lm

.PHONY: all clean

all: $(EXE)

$(EXE): $(OBJS)
	$(CC) $(CFLAGS) $(TARGET_ARCH) $^ $(LDFLAGS) -o $@

$(OBJ_DIR)/%.o: %.c
	mkdir -p $(@D)
	$(CC) $(CFLAGS) -c $< -o $@

$(OBJ_DIR):
	mkdir -p $@

clean:
	$(RM) -rv *~ $(OBJS) $(EXE)
